        ],
        "step": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "Select Right Weight",
            "text": "Choose a weighted item that is 5-10% of your child's body weight. For a 20kg child, start with 1-2kg.",
            "image": "https://pinnacleblooms.org/images/howto/step1-weight.jpg"
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Check Safety Requirements",
            "text": "Ensure child is over 12 months old, can remove the blanket independently, and has no respiratory conditions or low muscle tone.",
            "image": "https://pinnacleblooms.org/images/howto/step2-safety.jpg"
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "Introduce During Preferred Activities",
            "text": "First introduce the weighted blanket during activities your child already enjoys to build positive association.",
            "image": "https://pinnacleblooms.org/images/howto/step3-introduce.jpg"
          },
          {
            "@type": "HowToStep",
            "position": 4,
            "name": "Start with Short Sessions",
            "text": "Begin with 5-10 minute sessions. Observe your child's response. Gradually increase to 15-30 minutes.",
            "image": "https://pinnacleblooms.org/images/howto/step4-duration.jpg"
          },
          {
            "@type": "HowToStep",
            "position": 5,
            "name": "Use Proactively, Not Reactively",
            "text": "Apply BEFORE challenging activities, during transitions, or at early signs of dysregulation.",
            "image": "https://pinnacleblooms.org/images/howto/step5-proactive.jpg"
          },
          {
            "@type": "HowToStep",
            "position": 6,
            "name": "Monitor Child's Response",
            "text": "Watch for positive signs: calming, focusing, requesting more. Remove immediately if you see distress.",
            "image": "https://pinnacleblooms.org/images/howto/step6-monitor.jpg"
          },
          {
            "@type": "HowToStep",
            "position": 7,
            "name": "Track Progress and Adjust",
            "text": "Use the Pinnacle Blooms app to track usage, responses, and improvements over time.",
            "image": "https://pinnacleblooms.org/images/howto/step7-track.jpg"
          }
        ]
